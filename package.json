{
  "name": "study-assistant",
  "private": true,
  "scripts": {
    "dev": "parcel src/index.html",
    "prebuild": "npm run format:check && npm run typecheck && rm -rf dist",
    "build": "parcel build src/index.html --dist-dir dist --public-url ./ --no-source-maps --detailed-report",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "author": "Florian Hotze",
  "license": "MIT",
  "devDependencies": {
    "@parcel/optimizer-htmlnano": "^2.16.4",
    "parcel": "^2.16.4",
    "prettier": "^3.8.2",
    "svgo": "^3.3.3",
    "typescript": "^6.0.2"
  }
}
